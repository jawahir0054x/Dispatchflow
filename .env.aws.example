# =============================================================================
# AWS RDS — production / staging backend environment
# Copy to .env.aws and fill in values from Terraform outputs or AWS Console
# =============================================================================

SPRING_PROFILES_ACTIVE=prod

# RDS endpoint (from AWS Console or terraform output rds_endpoint)
DB_HOST=dispatchflow.xxxxxxxxxxxx.us-east-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=dispatchflow
DB_USERNAME=dispatchflow_admin
DB_PASSWORD=change-me-strong-password

# SSL required for RDS
DB_SSL_MODE=require

JWT_SECRET=change-me-to-a-long-random-production-secret
JWT_EXPIRATION_MS=86400000

CORS_ALLOWED_ORIGINS=https://app.yourdomain.com,https://admin.yourdomain.com

SEED_ADMIN=true
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-me-strong-admin-password
