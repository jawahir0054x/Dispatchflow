# =============================================================================
# DispatchFlow AI — root environment (backend + docker-compose)
# Copy to .env:  cp .env.example .env
# =============================================================================

# PostgreSQL — local Docker (see docs/aws-rds.md for AWS RDS production)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dispatchflow
DB_USERNAME=dispatchflow
DB_PASSWORD=dispatchflow

# JWT (change JWT_SECRET in production — min 32 characters)
JWT_SECRET=DispatchFlowSecretKeyForJWTSigningMustBeAtLeast32Chars
JWT_EXPIRATION_MS=86400000

# CORS — comma-separated frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Default admin user seeded on first startup
SEED_ADMIN=true
ADMIN_EMAIL=admin@dispatchflow.com
ADMIN_PASSWORD=admin12345
