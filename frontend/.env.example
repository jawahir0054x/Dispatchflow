# Dispatcher portal (Vite)
# Copy to .env:  cp .env.example .env

# API base URL — leave empty in dev (Vite proxies /api to localhost:8080)
# For production builds, set to your backend URL, e.g. https://api.dispatchflow.com
VITE_API_URL=

# Admin console URL (used when an admin signs in here)
VITE_ADMIN_URL=http://localhost:5174
