# Backend environment variables
# Spring Boot reads these from the process environment.
# When using `npm run dev` from the repo root, variables are loaded from ../.env
#
# You can also export them manually before running:
#   export $(grep -v '^#' ../.env | xargs)
#   ./mvnw spring-boot:run

DB_HOST=localhost
DB_PORT=5432
DB_NAME=dispatchflow
DB_USERNAME=dispatchflow
DB_PASSWORD=dispatchflow

JWT_SECRET=DispatchFlowSecretKeyForJWTSigningMustBeAtLeast32Chars
JWT_EXPIRATION_MS=86400000

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

SEED_ADMIN=true
ADMIN_EMAIL=admin@dispatchflow.com
ADMIN_PASSWORD=admin12345
